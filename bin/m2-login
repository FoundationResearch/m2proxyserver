#!/usr/bin/env bash
# m2-login: log in to MBZUAI HPC Teleport via Okta on the m2proxymachine jump host,
# then sync the issued cert back to ~/.tsh on this machine so local ssh / VS
# Code Remote-SSH can authenticate. Actual TCP exit is via the m2proxymachine, so
# the cluster only ever sees the m2proxymachine's IP.
#
# STRICT MODE (always on): the Okta URL is opened in an isolated Chromium
# browser profile that routes through an SSH SOCKS5 tunnel into m2proxymachine, so
# Okta and Teleport's web frontend ALSO only ever see the m2proxymachine IP — never
# your laptop's. Browser session stays in a dedicated profile under
# ~/Library/Caches/m2-login-okta-profile so Okta "trusted device" cookies
# persist there, but never touch your normal Chrome.
#
# Usage:  m2-login            # full login + cert sync (default)
#         m2-login status     # tsh status on m2proxymachine
#
# Note: there is intentionally NO `logout` subcommand. The cert is shared
# across all lab members on the m2proxymachine; allowing any member to wipe it would
# disrupt everyone. If revocation is genuinely needed, the m2proxymachine admin must
# do it manually:  ssh m2proxymachine-admin → sudo -u proxy /opt/homebrew/bin/tsh logout

set -uo pipefail

JUMP_HOST="m2proxymachine"
TELEPORT_PROXY="https://mbzuai-hpc.teleport.sh"
TELEPORT_USER="hao.zhang@mbzuai.ac.ae"
PORT=8765                # OAuth callback HTTP forwarder
SOCKS_PORT=51080         # SSH SOCKS5 dynamic forward
TSH="/opt/homebrew/bin/tsh"   # path on the remote jump host (m2proxymachine is macOS)
LOCAL_TSH_DIR="$HOME/.tsh"

# Browser profile cache path differs per OS — Library/Caches on macOS,
# XDG_CACHE_HOME (~/.cache) on Linux/WSL.
case "$(uname -s)" in
  Darwin) CHROME_PROFILE="$HOME/Library/Caches/m2-login-okta-profile" ;;
  Linux)  CHROME_PROFILE="${XDG_CACHE_HOME:-$HOME/.cache}/m2-login-okta-profile" ;;
  *)      CHROME_PROFILE="$HOME/.m2-login-okta-profile" ;;
esac
IS_WSL=""
if grep -qiE 'microsoft|wsl' /proc/sys/kernel/osrelease 2>/dev/null; then
  IS_WSL=1
fi

# Self-update: this URL is per-branch — main checks main, wsl checks wsl.
M2_RAW_URL="https://raw.githubusercontent.com/FoundationResearch/m2proxyserver/wsl/bin/m2-login"
UPDATE_CHECK_CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/m2-login-update-check"
UPDATE_CHECK_TTL=86400   # 24h between auto-checks

log() { printf '\033[1;34m→\033[0m %s\n' "$*"; }
ok()  { printf '\033[1;32m✓\033[0m %s\n' "$*"; }
warn(){ printf '\033[1;33m!\033[0m %s\n' "$*"; }
err() { printf '\033[1;31m✗\033[0m %s\n' "$*" >&2; }

ssh_retry() {
  local i out rc
  for i in 1 2 3 4 5 6 7 8; do
    out=$(ssh -o ConnectTimeout=10 "$@" 2>&1)
    rc=$?
    if [ $rc -eq 0 ]; then
      printf '%s\n' "$out"
      return 0
    fi
    sleep 2
  done
  printf '%s\n' "$out" >&2
  return 1
}

# Quietly check if a newer m2-login is available on the configured branch.
# Prompts to apply (Y/n). Re-execs the new version on apply.
#
# Called from the interactive `login` flow only — never from `check`
# (which runs on every ssh; can't tolerate a 5s curl) or `status`.
# Skips silently if curl is missing, network down, no /dev/tty, or the
# user set M2_LOGIN_NO_UPDATE_CHECK=1. 24h cache so we don't nag.
check_for_updates() {
  local force=""
  [ "${1:-}" = "force" ] && { force=1; shift; }
  [ -n "${M2_LOGIN_NO_UPDATE_CHECK:-}" ] && return 0
  command -v curl >/dev/null 2>&1 || return 0

  if [ -z "$force" ] && [ -f "$UPDATE_CHECK_CACHE" ]; then
    local last_check
    last_check=$(cat "$UPDATE_CHECK_CACHE" 2>/dev/null || echo 0)
    [ $(($(date +%s) - last_check)) -lt $UPDATE_CHECK_TTL ] && return 0
  fi

  local self tmp
  self="$(realpath "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
  tmp=$(mktemp -t m2-login.update.XXXXXX 2>/dev/null) || return 0

  if ! curl -fsSL --max-time 5 "$M2_RAW_URL" -o "$tmp" 2>/dev/null; then
    rm -f "$tmp"; return 0
  fi

  mkdir -p "$(dirname "$UPDATE_CHECK_CACHE")"
  date +%s > "$UPDATE_CHECK_CACHE"

  if cmp -s "$tmp" "$self"; then
    rm -f "$tmp"; return 0
  fi

  warn "An update for m2-login is available."
  printf '\033[1;35m?\033[0m Apply update now? [Y/n] '
  local reply=""
  # /dev/tty may be readable as a device node yet error on actual open
  # (no controlling terminal — e.g. cron, CI, or piped input). The error
  # from the `< /dev/tty` redirection setup escapes bash's own stderr
  # *before* any -r/2>/dev/null on `read` itself, so wrap the entire
  # group to suppress it. Then default to Y below.
  if [ -r /dev/tty ]; then
    { read -r reply < /dev/tty || reply=""; } 2>/dev/null
  fi
  if [[ "${reply:-Y}" =~ ^[Nn]$ ]]; then
    log "Update skipped (will ask again in 24h; force with: m2-login update)."
    rm -f "$tmp"
    return 0
  fi

  if ! install -m 755 "$tmp" "$self" 2>/dev/null; then
    err "Could not write to $self — update aborted."
    rm -f "$tmp"; return 0
  fi
  rm -f "$tmp"
  ok "Updated. Re-launching with new version..."
  exec "$self" "$@"
}

# Inspect the local Teleport cert with ssh-keygen and return seconds until
# expiry. Echoes -1 if the cert is missing or unparseable.
local_cert_remaining() {
  local cert valid_to exp
  cert="$LOCAL_TSH_DIR/keys/mbzuai-hpc.teleport.sh/${TELEPORT_USER}-ssh/mbzuai-hpc.teleport.sh-cert.pub"
  [ -f "$cert" ] || { echo -1; return; }
  # ssh-keygen -L prints "        Valid: from <iso> to <iso>"
  valid_to=$(ssh-keygen -L -f "$cert" 2>/dev/null | awk '/Valid:/ {print $5}')
  [ -z "$valid_to" ] && { echo -1; return; }
  # macOS BSD date vs Linux GNU date — try both.
  exp=$(date -j -f "%Y-%m-%dT%H:%M:%S" "$valid_to" +%s 2>/dev/null) \
    || exp=$(date -d "$valid_to" +%s 2>/dev/null) \
    || { echo -1; return; }
  echo $((exp - $(date +%s)))
}

case "${1:-login}" in
  status)
    ssh_retry "$JUMP_HOST" "$TSH status"
    exit $?
    ;;
  update)
    shift || true
    check_for_updates force "$@"
    ok "Already up to date."
    exit 0
    ;;
  check)
    # Hook for ssh ProxyCommand: ensure the Teleport cert is usable, in a
    # non-interactive way that NEVER opens Okta. Three outcomes:
    #   exit 0 — local cert valid (silent), or just refreshed via fast path
    #   exit 1 — refresh would require Okta, user must run `m2-login` themself
    # Designed to add ~10ms to every `ssh m2-login-*` when cert is fresh.
    #
    # NOTE on WSL: the sync_cert here only updates the WSL-side ~/.tsh/.
    # If the user is also using Windows-native ssh (VS Code etc.), they
    # should run `m2-login` from WSL to get the Windows-side .tsh\
    # mirror updated too — this fast-path skips that.
    remaining=$(local_cert_remaining)
    if [ "$remaining" -gt 300 ]; then
      exit 0
    fi
    # Local cert expired (or expiring within 5 min). See if the shared cert
    # on the jump host is fresh — if so, just rsync it down silently.
    quick_status=$(ssh -o ConnectTimeout=10 "$JUMP_HOST" \
      "$TSH status 2>/dev/null | grep '\\[valid for'" 2>/dev/null || true)
    if echo "$quick_status" | grep -qE '\[valid for [1-9][0-9]*h'; then
      printf '\033[1;34m→\033[0m Local cert stale; pulling fresh shared cert from %s...\n' "$JUMP_HOST" >&2
      # Inline rsync (the elaborate sync_cert with Windows mirror is defined
      # later and depends on functions defined later still — too much to
      # hoist for a hook that runs before --check parses anything else).
      mkdir -p "$LOCAL_TSH_DIR"
      if ! rsync -a -e "ssh -o ConnectTimeout=15" "${JUMP_HOST}:.tsh/keys/" "${LOCAL_TSH_DIR}/keys/" >&2; then
        err "cert sync failed"
        exit 1
      fi
      rsync -a -e "ssh -o ConnectTimeout=15" \
        "${JUMP_HOST}:.tsh/current-profile" \
        "${JUMP_HOST}:.tsh/mbzuai-hpc.teleport.sh.yaml" \
        "${JUMP_HOST}:.tsh/known_hosts" \
        "${LOCAL_TSH_DIR}/" 2>/dev/null || true
      chmod 700 "${LOCAL_TSH_DIR}/keys" 2>/dev/null || true
      find "${LOCAL_TSH_DIR}/keys" -type d -exec chmod 700 {} + 2>/dev/null || true
      find "${LOCAL_TSH_DIR}/keys" -type f -exec chmod 600 {} + 2>/dev/null || true
      exit 0
    fi
    # Both stale. Don't auto-Okta from inside an ssh ProxyCommand —
    # it would mean a Chrome window unexpectedly popping up while the
    # user thought they were just typing `ssh m2-login-001`, and the
    # OAuth callback could time out before they complete it.
    err "Teleport cert is expired and a fresh one needs Okta SSO."
    err "Run interactively first:   m2-login"
    err "then retry your ssh / VS Code Remote-SSH / scp / rsync."
    exit 1
    ;;
  login|"")
    ;;
  logout)
    err "logout is intentionally disabled — wiping the shared cert disrupts everyone."
    err "If you really need to revoke, contact the m2proxymachine admin."
    exit 2
    ;;
  *)
    err "unknown command: $1 (use: login | status | check | update)"
    exit 2
    ;;
esac

# Auto-update check (interactive login flow only — fast no-op if cached)
check_for_updates "$@"

# Locate a Chromium-family browser. Strict mode requires one because Safari
# and Firefox don't support per-instance proxy via CLI flags.
find_browser() {
  local app cmd
  case "$(uname -s)" in
    Darwin)
      for app in \
        "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
        "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser" \
        "/Applications/Chromium.app/Contents/MacOS/Chromium" \
        "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge" \
        "/Applications/Arc.app/Contents/MacOS/Arc"; do
        if [ -x "$app" ]; then
          printf '%s' "$app"
          return 0
        fi
      done
      ;;
    Linux)
      for cmd in google-chrome google-chrome-stable chromium chromium-browser brave-browser microsoft-edge microsoft-edge-stable; do
        if command -v "$cmd" >/dev/null 2>&1; then
          command -v "$cmd"
          return 0
        fi
      done
      # WSL fallback: a Windows-side Chromium browser. WSL2 forwards localhost
      # so socks5://localhost:51080 works from Windows-side too.
      if [ -n "$IS_WSL" ]; then
        for app in \
          "/mnt/c/Program Files/Google/Chrome/Application/chrome.exe" \
          "/mnt/c/Program Files (x86)/Google/Chrome/Application/chrome.exe" \
          "/mnt/c/Program Files (x86)/Microsoft/Edge/Application/msedge.exe" \
          "/mnt/c/Program Files/Microsoft/Edge/Application/msedge.exe" \
          "/mnt/c/Program Files/BraveSoftware/Brave-Browser/Application/brave.exe"; do
          if [ -x "$app" ]; then
            printf '%s' "$app"
            return 0
          fi
        done
      fi
      ;;
  esac
  return 1
}

CHROME=""
if ! CHROME=$(find_browser); then
  err "STRICT mode requires a Chromium-family browser (Chrome / Brave / Edge / Chromium / Arc)."
  case "$(uname -s)" in
    Darwin) err "Install Chrome:  brew install --cask google-chrome" ;;
    Linux)
      if [ -n "$IS_WSL" ]; then
        err "On WSL: install Microsoft Edge or Chrome on Windows, or apt install chromium."
      else
        err "Install Chromium:  sudo apt-get install -y chromium  (or chromium-browser)"
        err "Or download Chrome: https://www.google.com/chrome/"
      fi
      ;;
  esac
  err "We refuse to fall back to your default browser because that would leak"
  err "your laptop's IP to Okta — defeating the whole point of the jump host."
  exit 1
fi

# Drift check: warn if /etc/hosts pin for ssh.alexzms.com no longer matches
# Cloudflare's current DNS. CF anycast + SNI-routing means stale IPs usually
# still work, but if ssh starts dying with "no route to host", refreshing the
# /etc/hosts pin is the fix. Always returns 0 so the script never blocks on
# this check (e.g. when offline).
check_etc_hosts_drift() {
  local pinned_ips dns_ips ip
  pinned_ips=$(grep -wE 'ssh\.alexzms\.com' /etc/hosts 2>/dev/null \
    | grep -v '^[[:space:]]*#' \
    | awk '{print $1}' \
    | grep -E '^[0-9.]+$' \
    | sort -u)
  [ -z "$pinned_ips" ] && return 0
  dns_ips=$(dig @1.1.1.1 +short +time=2 +tries=1 A ssh.alexzms.com 2>/dev/null \
    | grep -E '^[0-9.]+$' \
    | sort -u)
  [ -z "$dns_ips" ] && return 0
  for ip in $pinned_ips; do
    if ! grep -qw "$ip" <<< "$dns_ips"; then
      warn "/etc/hosts pin for ssh.alexzms.com no longer matches Cloudflare DNS:"
      warn "  pinned: $(echo $pinned_ips | tr '\n' ' ')"
      warn "  DNS:    $(echo $dns_ips | tr '\n' ' ')"
      warn "Usually still works (CF anycast + SNI routing). If you start seeing"
      warn "'dial tcp ...: no route to host', refresh by re-running setup.sh —"
      warn "it will dig the current IPs and rewrite /etc/hosts automatically:"
      warn "    curl -fsSL https://raw.githubusercontent.com/FoundationResearch/m2proxyserver/main/setup.sh | bash"
      break
    fi
  done
  return 0
}

# Kill any ssh process listening on the given local port. More robust than
# pkill -f matching, which is fragile to ssh option ordering.
kill_listener() {
  local port=$1
  local pid
  # -a ANDs the selectors (default is OR), so this only matches ssh procs
  # that are listening on the given port — not every ssh process on the box.
  pid=$(lsof -a -nP -i tcp:${port} -sTCP:LISTEN -c ssh -t 2>/dev/null | head -1)
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null || true
  fi
}

cleanup() {
  kill_listener "$PORT"
  kill_listener "$SOCKS_PORT"
}
trap cleanup EXIT INT TERM

check_etc_hosts_drift

# Sync the cert files from the jump host to the local ~/.tsh/. Used both by
# the "cert is already fresh" fast path and after a fresh tsh login. The
# files are tiny (a few KB) and the same for everyone, so this is safe to
# run any time.
# Resolve the Windows-side ~/.tsh dir on WSL via cmd.exe %USERPROFILE%, so we
# can keep a Windows-native copy in lockstep. Empty stdout = no mirror.
detect_wsl_tsh_mirror() {
  [ -n "${M2_LOGIN_WIN_TSH_DIR:-}" ] && { printf '%s' "$M2_LOGIN_WIN_TSH_DIR"; return 0; }
  [ -z "$IS_WSL" ] && return 0
  command -v cmd.exe >/dev/null 2>&1 || return 0
  command -v wslpath >/dev/null 2>&1 || return 0
  local up p
  # Run cmd.exe from /mnt/c so it doesn't whine about UNC cwd.
  up=$(cd /mnt/c 2>/dev/null && cmd.exe /c "echo %USERPROFILE%" 2>/dev/null | tr -d '\r\n')
  [ -z "$up" ] && return 0
  p=$(wslpath -u "$up" 2>/dev/null) || return 0
  [ -z "$p" ] || [ ! -d "$p" ] && return 0
  printf '%s/.tsh' "$p"
}

sync_cert() {
  log "Syncing cert files to ${LOCAL_TSH_DIR}/"
  mkdir -p "$LOCAL_TSH_DIR"

  # Refuse to write into a symlink that points at /mnt/* — DrvFs reports
  # every file as 0777 there, which OpenSSH rejects with "permissions too
  # open". Bail loudly instead of silently producing an unusable cert.
  if [ -L "${LOCAL_TSH_DIR}/keys" ]; then
    local link_target
    link_target=$(readlink -f "${LOCAL_TSH_DIR}/keys" 2>/dev/null \
                  || readlink "${LOCAL_TSH_DIR}/keys")
    case "$link_target" in
      /mnt/*)
        err "${LOCAL_TSH_DIR}/keys is a symlink into a Windows mount ($link_target)."
        err "DrvFs reports all files there as 0777 → ssh refuses to load the key."
        err "Remove the symlink and re-run:"
        err "    rm '${LOCAL_TSH_DIR}/keys'"
        exit 1
        ;;
    esac
  fi

  if ! rsync -a -e "ssh -o ConnectTimeout=15" "${JUMP_HOST}:.tsh/keys/" "${LOCAL_TSH_DIR}/keys/"; then
    err "cert sync failed"
    exit 1
  fi
  rsync -a -e "ssh -o ConnectTimeout=15" \
    "${JUMP_HOST}:.tsh/current-profile" \
    "${JUMP_HOST}:.tsh/mbzuai-hpc.teleport.sh.yaml" \
    "${JUMP_HOST}:.tsh/known_hosts" \
    "${LOCAL_TSH_DIR}/" 2>/dev/null || true

  # Tighten perms unconditionally. rsync -a preserves source perms, but a
  # restrictive consumer (OpenSSH) reads its own bits regardless of how the
  # cert got there — and a careless mount or umask can still leave stuff
  # group/world-readable. Strip g+o entirely under keys/.
  chmod 700 "${LOCAL_TSH_DIR}/keys" 2>/dev/null || true
  find "${LOCAL_TSH_DIR}/keys" -type d -exec chmod 700 {} + 2>/dev/null || true
  find "${LOCAL_TSH_DIR}/keys" -type f -exec chmod 600 {} + 2>/dev/null || true
  chmod 600 "${LOCAL_TSH_DIR}/known_hosts" 2>/dev/null || true

  # WSL: keep a copy on the Windows side too (Windows-native tsh/SSH can
  # use it directly). DrvFs ignores Unix perms, but the WSL-native copy
  # above is what ssh on Linux loads, so the loose Windows-side mode is
  # not a problem here.
  local win_tsh
  win_tsh=$(detect_wsl_tsh_mirror)
  if [ -n "$win_tsh" ]; then
    log "Mirroring cert to Windows side: $win_tsh/"
    mkdir -p "$win_tsh/keys"
    if rsync -a --delete --no-perms --no-owner --no-group \
         "${LOCAL_TSH_DIR}/keys/" "$win_tsh/keys/" 2>/dev/null; then
      cp -f "${LOCAL_TSH_DIR}/current-profile" "$win_tsh/" 2>/dev/null || true
      cp -f "${LOCAL_TSH_DIR}/mbzuai-hpc.teleport.sh.yaml" "$win_tsh/" 2>/dev/null || true
      cp -f "${LOCAL_TSH_DIR}/known_hosts" "$win_tsh/" 2>/dev/null || true
      ok "Windows mirror updated"
    else
      warn "Windows mirror failed (continuing — WSL-native cert is fine)"
    fi
  fi
}

# Fast path: if the shared cert on the jump host still has >=1h left, skip
# the entire Okta dance — just rsync it down. Cuts the common case (the
# first lab member of the day refreshed it; everyone else just inherits)
# from a 30s tunnel-and-browser ritual to a sub-second sync.
log "Checking remote cert freshness on ${JUMP_HOST}"
quick_status=$(ssh -o ConnectTimeout=10 "$JUMP_HOST" "$TSH status 2>/dev/null | grep '\\[valid for'" 2>/dev/null || true)
if echo "$quick_status" | grep -qE '\[valid for [1-9][0-9]*h'; then
  ok "Cert is still fresh: $(echo "$quick_status" | grep -oE '\[valid for [^]]+\]')"
  log "Skipping Okta — pulling existing cert."
  sync_cert
  ok "Done. Final status:"
  ssh_retry "$JUMP_HOST" "$TSH status"
  exit 0
fi

kill_listener "$PORT"
kill_listener "$SOCKS_PORT"
sleep 1

# ---- 1. OAuth callback port forward (localhost:8765 → m2proxymachine:8765) ----
log "Establishing port forward localhost:${PORT} → ${JUMP_HOST}:${PORT}"
forward_up=0
for try in 1 2 3 4 5; do
  ssh -o ConnectTimeout=10 -f -N -L "${PORT}:127.0.0.1:${PORT}" "$JUMP_HOST" 2>/dev/null
  sleep 1
  if lsof -nP -i tcp:${PORT} -sTCP:LISTEN >/dev/null 2>&1; then
    forward_up=1
    ok "callback forward up (attempt ${try})"
    break
  fi
  kill_listener "$PORT"
  sleep 2
done
[ $forward_up -eq 0 ] && { err "could not establish callback forward"; exit 1; }

# ---- 2. SOCKS5 tunnel (browser → m2proxymachine → Okta/Teleport web) ----
log "Establishing SOCKS5 tunnel localhost:${SOCKS_PORT} → ${JUMP_HOST} (egress for browser)"
socks_up=0
for try in 1 2 3 4 5; do
  ssh -o ConnectTimeout=10 -D ${SOCKS_PORT} -f -N "$JUMP_HOST" 2>/dev/null
  sleep 1
  if lsof -nP -i tcp:${SOCKS_PORT} -sTCP:LISTEN >/dev/null 2>&1; then
    socks_up=1
    ok "SOCKS5 up (attempt ${try})"
    break
  fi
  kill_listener "$SOCKS_PORT"
  sleep 2
done
[ $socks_up -eq 0 ] && { err "could not establish SOCKS5 tunnel"; exit 1; }

# ---- 3. tsh login on m2proxymachine, watch for the OAuth URL ----
# Serialized on the jump host with an atomic-mkdir lock (flock isn't
# shipped on macOS) so concurrent m2-login invocations don't fight over
# the OAuth callback bind-addr. The first one through does Okta; everyone
# else blocks on the lock and then re-checks the cert — by then it's
# fresh and they fall straight into the rsync.
mkdir -p "$CHROME_PROFILE"
log "Browser: $CHROME"
log "Profile: $CHROME_PROFILE  (isolated; Okta cookies persist here only)"
log "Starting tsh login on ${JUMP_HOST}. If Okta is needed, an isolated Chrome window will open via SOCKS."

opened=""
cert_fresh=""
# Regex matches the OAuth callback URL tsh prints. We use it twice:
#   1. as a *filter* — never echo a line containing it, because every
#      modern terminal (iTerm/Terminal/kitty/wezterm/Windows Terminal)
#      auto-linkifies URLs and Cmd/Ctrl-clicking opens the system *default*
#      browser. That bypasses our SOCKS5 + isolated profile and leaks the
#      laptop's IP to Okta.
#   2. as the actual URL we hand to the locked-down Chrome instance.
URL_RE='http://127\.0\.0\.1:[0-9]+/[a-zA-Z0-9-]+'
while IFS= read -r line; do
  if [[ "$line" =~ $URL_RE ]]; then
    URL="${BASH_REMATCH[0]}"
    if [ -z "$cert_fresh" ] && [ -z "$opened" ]; then
      printf '\033[1;36m→ OAuth URL received — opening in isolated Chrome via SOCKS5.\033[0m\n'
      printf '\033[2m  (URL deliberately withheld so it can'"'"'t be Cmd/Ctrl-clicked into your default browser, which would leak your IP to Okta.)\033[0m\n'
      # Lock the browser down so Okta's network-level audit log only ever sees
      # the m2proxymachine IP — no laptop fingerprint:
      #   --proxy-server  all HTTP/HTTPS via SOCKS5; DNS too since socks5:// (not socks://)
      #                   makes Chrome resolve hostnames remotely through the proxy.
      #                   IPv6 destinations also go through SOCKS5, which supports them,
      #                   so dual-stack hosts don't bypass.
      #   --force-webrtc-ip-handling-policy=disable_non_proxied_udp
      #                   kills WebRTC's UDP entirely when no UDP proxy exists.
      #                   This blocks both STUN (which would otherwise leak the
      #                   laptop's WAN IP) and mDNS host candidates (which would
      #                   leak the laptop's LAN hostname/IP).
      #   --disable-background-networking / --disable-sync / --disable-component-update
      #   --disable-default-apps / --no-pings
      #                   silence Chrome's chatty side traffic so nothing
      #                   non-Okta accidentally fires a non-proxied request.
      # If we picked a Windows-side browser (WSL fallback), --user-data-dir
      # must be a Windows path or Chrome silently falls back to the default
      # profile — defeating the isolation.
      profile_arg="$CHROME_PROFILE"
      if [[ "$CHROME" == /mnt/c/* ]] && command -v wslpath >/dev/null 2>&1; then
        mkdir -p "$CHROME_PROFILE"
        profile_arg=$(wslpath -w "$CHROME_PROFILE")
      fi
      "$CHROME" \
        --user-data-dir="$profile_arg" \
        --proxy-server="socks5://localhost:${SOCKS_PORT}" \
        --proxy-bypass-list="127.0.0.1,localhost" \
        --force-webrtc-ip-handling-policy=disable_non_proxied_udp \
        --disable-background-networking \
        --disable-component-update \
        --disable-sync \
        --disable-default-apps \
        --no-pings \
        --no-first-run \
        --no-default-browser-check \
        --new-window \
        "$URL" >/dev/null 2>&1 &
      opened=1
    fi
    continue
  fi
  printf '%s\n' "$line"
  case "$line" in
    M2LOGIN_WAITING_LOCK)
      warn "Another m2-login is already running on ${JUMP_HOST}. Waiting for it to finish…"
      ;;
    M2LOGIN_CERT_FRESH)
      ok "Another lab member just refreshed the cert — skipping Okta."
      cert_fresh=1
      ;;
  esac
done < <(
  ssh -o ServerAliveInterval=30 "$JUMP_HOST" "
    LOCKDIR=/tmp/m2-login.lock.d
    waited=0
    # Atomic lock: mkdir is the only POSIX primitive that's reliably atomic
    # across macOS without extra deps. Stale lock cleared after 5 min to
    # protect against a crashed previous run leaving the dir behind.
    while ! mkdir \"\$LOCKDIR\" 2>/dev/null; do
      if [ \$waited -eq 0 ]; then echo M2LOGIN_WAITING_LOCK; fi
      waited=\$((waited+1))
      if [ \$waited -gt 300 ]; then
        # Treat a >5min-old dir as stale (probably a crashed previous run).
        if [ -n \"\$(find \"\$LOCKDIR\" -maxdepth 0 -mmin +5 2>/dev/null)\" ]; then
          rmdir \"\$LOCKDIR\" 2>/dev/null
          waited=0
          continue
        fi
        echo 'lock wait timeout (5 min)' >&2
        exit 1
      fi
      sleep 1
    done
    trap 'rmdir \"\$LOCKDIR\" 2>/dev/null' EXIT
    # Re-check after acquiring the lock — someone else may have just refreshed.
    if $TSH status 2>/dev/null | grep -qE '\\[valid for [1-9][0-9]*h'; then
      echo M2LOGIN_CERT_FRESH
      exit 0
    fi
    $TSH login --proxy=$TELEPORT_PROXY --user=$TELEPORT_USER --auth=okta --browser=none --bind-addr=127.0.0.1:${PORT}
  " 2>&1
)

# ---- 4. Verify cert ----
log "Verifying tsh status on ${JUMP_HOST}"
if ! ssh_retry "$JUMP_HOST" "$TSH status" >/dev/null; then
  err "tsh status failed — login likely did not complete"
  exit 1
fi

# ---- 5. Sync cert back to local ----
sync_cert

ok "logged in. Final status:"
ssh_retry "$JUMP_HOST" "$TSH status"

if [ -n "$opened" ]; then
  echo
  warn "You may now close the m2-login Chrome window. (The SOCKS tunnel will be torn down when this script exits — any further browsing in that window will fail until next m2-login.)"
fi
