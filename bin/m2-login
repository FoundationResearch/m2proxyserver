#!/usr/bin/env bash
# m2-login: log in to MBZUAI HPC Teleport via Okta on the macmini jump host,
# then sync the issued cert back to ~/.tsh on this machine so local ssh / VS
# Code Remote-SSH can authenticate. Actual TCP exit is via the macmini, so
# the cluster only ever sees the macmini's IP.
#
# STRICT MODE (always on): the Okta URL is opened in an isolated Chromium
# browser profile that routes through an SSH SOCKS5 tunnel into macmini, so
# Okta and Teleport's web frontend ALSO only ever see the macmini IP — never
# your laptop's. Browser session stays in a dedicated profile under
# ~/Library/Caches/m2-login-okta-profile so Okta "trusted device" cookies
# persist there, but never touch your normal Chrome.
#
# Usage:  m2-login            # full login + cert sync (default)
#         m2-login status     # tsh status on macmini
#
# Note: there is intentionally NO `logout` subcommand. The cert is shared
# across all lab members on the macmini; allowing any member to wipe it would
# disrupt everyone. If revocation is genuinely needed, the macmini admin must
# do it manually:  ssh macmini-admin → sudo -u proxy /opt/homebrew/bin/tsh logout

set -uo pipefail

JUMP_HOST="macmini"
TELEPORT_PROXY="https://mbzuai-hpc.teleport.sh"
TELEPORT_USER="hao.zhang@mbzuai.ac.ae"
PORT=8765                # OAuth callback HTTP forwarder
SOCKS_PORT=51080         # SSH SOCKS5 dynamic forward
TSH="/opt/homebrew/bin/tsh"
LOCAL_TSH_DIR="$HOME/.tsh"
CHROME_PROFILE="$HOME/Library/Caches/m2-login-okta-profile"

log() { printf '\033[1;34m→\033[0m %s\n' "$*"; }
ok()  { printf '\033[1;32m✓\033[0m %s\n' "$*"; }
warn(){ printf '\033[1;33m!\033[0m %s\n' "$*"; }
err() { printf '\033[1;31m✗\033[0m %s\n' "$*" >&2; }

ssh_retry() {
  local i out rc
  for i in 1 2 3 4 5 6 7 8; do
    out=$(ssh -o ConnectTimeout=10 "$@" 2>&1)
    rc=$?
    if [ $rc -eq 0 ]; then
      printf '%s\n' "$out"
      return 0
    fi
    sleep 2
  done
  printf '%s\n' "$out" >&2
  return 1
}

case "${1:-login}" in
  status)
    ssh_retry "$JUMP_HOST" "$TSH status"
    exit $?
    ;;
  login|"")
    ;;
  logout)
    err "logout is intentionally disabled — wiping the shared cert disrupts everyone."
    err "If you really need to revoke, contact the macmini admin."
    exit 2
    ;;
  *)
    err "unknown command: $1 (use: login | status)"
    exit 2
    ;;
esac

# Locate a Chromium-family browser. Strict mode requires one because Safari
# and Firefox don't support per-instance proxy via CLI flags on macOS.
find_browser() {
  for app in \
    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
    "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser" \
    "/Applications/Chromium.app/Contents/MacOS/Chromium" \
    "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge" \
    "/Applications/Arc.app/Contents/MacOS/Arc"; do
    if [ -x "$app" ]; then
      printf '%s' "$app"
      return 0
    fi
  done
  return 1
}

CHROME=""
if ! CHROME=$(find_browser); then
  err "STRICT mode requires a Chromium-family browser (Chrome / Brave / Edge / Chromium / Arc)."
  err "Install Chrome:  brew install --cask google-chrome"
  err "We refuse to fall back to your default browser because that would leak"
  err "your laptop's IP to Okta — defeating the whole point of the jump host."
  exit 1
fi

# Drift check: warn if /etc/hosts pin for ssh.alexzms.com no longer matches
# Cloudflare's current DNS. CF anycast + SNI-routing means stale IPs usually
# still work, but if ssh starts dying with "no route to host", refreshing the
# /etc/hosts pin is the fix. Always returns 0 so the script never blocks on
# this check (e.g. when offline).
check_etc_hosts_drift() {
  local pinned_ips dns_ips ip
  pinned_ips=$(grep -wE 'ssh\.alexzms\.com' /etc/hosts 2>/dev/null \
    | grep -v '^[[:space:]]*#' \
    | awk '{print $1}' \
    | grep -E '^[0-9.]+$' \
    | sort -u)
  [ -z "$pinned_ips" ] && return 0
  dns_ips=$(dig @1.1.1.1 +short +time=2 +tries=1 A ssh.alexzms.com 2>/dev/null \
    | grep -E '^[0-9.]+$' \
    | sort -u)
  [ -z "$dns_ips" ] && return 0
  for ip in $pinned_ips; do
    if ! grep -qw "$ip" <<< "$dns_ips"; then
      warn "/etc/hosts pin for ssh.alexzms.com no longer matches Cloudflare DNS:"
      warn "  pinned: $(echo $pinned_ips | tr '\n' ' ')"
      warn "  DNS:    $(echo $dns_ips | tr '\n' ' ')"
      warn "Usually still works (CF anycast + SNI routing). If you start seeing"
      warn "'dial tcp ...: no route to host', refresh by re-running:"
      warn "    sudo sed -i '' '/m2proxyserver/,+2d' /etc/hosts"
      warn "    curl -fsSL https://raw.githubusercontent.com/FoundationResearch/m2proxyserver/main/setup.sh | bash"
      break
    fi
  done
  return 0
}

# Kill any ssh process listening on the given local port. More robust than
# pkill -f matching, which is fragile to ssh option ordering.
kill_listener() {
  local port=$1
  local pid
  # -a ANDs the selectors (default is OR), so this only matches ssh procs
  # that are listening on the given port — not every ssh process on the box.
  pid=$(lsof -a -nP -i tcp:${port} -sTCP:LISTEN -c ssh -t 2>/dev/null | head -1)
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null || true
  fi
}

cleanup() {
  kill_listener "$PORT"
  kill_listener "$SOCKS_PORT"
}
trap cleanup EXIT INT TERM

check_etc_hosts_drift

kill_listener "$PORT"
kill_listener "$SOCKS_PORT"
sleep 1

# ---- 1. OAuth callback port forward (localhost:8765 → macmini:8765) ----
log "Establishing port forward localhost:${PORT} → ${JUMP_HOST}:${PORT}"
forward_up=0
for try in 1 2 3 4 5; do
  ssh -o ConnectTimeout=10 -f -N -L "${PORT}:127.0.0.1:${PORT}" "$JUMP_HOST" 2>/dev/null
  sleep 1
  if lsof -nP -i tcp:${PORT} -sTCP:LISTEN >/dev/null 2>&1; then
    forward_up=1
    ok "callback forward up (attempt ${try})"
    break
  fi
  kill_listener "$PORT"
  sleep 2
done
[ $forward_up -eq 0 ] && { err "could not establish callback forward"; exit 1; }

# ---- 2. SOCKS5 tunnel (browser → macmini → Okta/Teleport web) ----
log "Establishing SOCKS5 tunnel localhost:${SOCKS_PORT} → ${JUMP_HOST} (egress for browser)"
socks_up=0
for try in 1 2 3 4 5; do
  ssh -o ConnectTimeout=10 -D ${SOCKS_PORT} -f -N "$JUMP_HOST" 2>/dev/null
  sleep 1
  if lsof -nP -i tcp:${SOCKS_PORT} -sTCP:LISTEN >/dev/null 2>&1; then
    socks_up=1
    ok "SOCKS5 up (attempt ${try})"
    break
  fi
  kill_listener "$SOCKS_PORT"
  sleep 2
done
[ $socks_up -eq 0 ] && { err "could not establish SOCKS5 tunnel"; exit 1; }

# ---- 3. tsh login on macmini, watch for the OAuth URL ----
mkdir -p "$CHROME_PROFILE"
log "Browser: $CHROME"
log "Profile: $CHROME_PROFILE  (isolated; Okta cookies persist here only)"
log "Starting tsh login on ${JUMP_HOST}. If Okta is needed, an isolated Chrome window will open via SOCKS."

opened=""
ssh -o ServerAliveInterval=30 "$JUMP_HOST" \
  "$TSH login --proxy=$TELEPORT_PROXY --user=$TELEPORT_USER --auth=okta --browser=none --bind-addr=127.0.0.1:${PORT}" 2>&1 \
| while IFS= read -r line; do
    printf '%s\n' "$line"
    if [ -z "$opened" ] && [[ "$line" =~ http://127\.0\.0\.1:[0-9]+/[a-zA-Z0-9-]+ ]]; then
      URL="${BASH_REMATCH[0]}"
      printf '\033[1;36m→ Opening URL via SOCKS5/macmini in isolated Chrome:\n  %s\033[0m\n' "$URL"
      "$CHROME" \
        --user-data-dir="$CHROME_PROFILE" \
        --proxy-server="socks5://localhost:${SOCKS_PORT}" \
        --proxy-bypass-list="127.0.0.1,localhost" \
        --no-first-run \
        --no-default-browser-check \
        --new-window \
        "$URL" >/dev/null 2>&1 &
      opened=1
    fi
  done

# ---- 4. Verify cert ----
log "Verifying tsh status on ${JUMP_HOST}"
if ! ssh_retry "$JUMP_HOST" "$TSH status" >/dev/null; then
  err "tsh status failed — login likely did not complete"
  exit 1
fi

# ---- 5. Sync cert back to local ----
log "Syncing cert files to ${LOCAL_TSH_DIR}/"
mkdir -p "$LOCAL_TSH_DIR"
if ! rsync -a -e "ssh -o ConnectTimeout=15" "${JUMP_HOST}:.tsh/keys/" "${LOCAL_TSH_DIR}/keys/"; then
  err "cert sync failed"
  exit 1
fi
rsync -a -e "ssh -o ConnectTimeout=15" \
  "${JUMP_HOST}:.tsh/current-profile" \
  "${JUMP_HOST}:.tsh/mbzuai-hpc.teleport.sh.yaml" \
  "${JUMP_HOST}:.tsh/known_hosts" \
  "${LOCAL_TSH_DIR}/" 2>/dev/null || true

ok "logged in. Final status:"
ssh_retry "$JUMP_HOST" "$TSH status"

if [ -n "$opened" ]; then
  echo
  warn "You may now close the m2-login Chrome window. (The SOCKS tunnel will be torn down when this script exits — any further browsing in that window will fail until next m2-login.)"
fi
